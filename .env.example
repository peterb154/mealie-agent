# Copy to .env and edit. docker-compose auto-loads .env from this directory.

# --- Model -----------------------------------------------------------------
STRANDS_PG_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
AWS_REGION=us-east-1

# --- AWS credentials -------------------------------------------------------
# Static IAM user keys. Create a dedicated IAM user (e.g. `mealie-agent-<host>`)
# scoped narrowly to bedrock:InvokeModel on the model ARNs you use. Rotate on
# a schedule. Don't reuse across agents.
#
# For laptop dev use AWS_PROFILE instead, and add a `${HOME}/.aws:/root/.aws`
# mount back into docker-compose.yml.
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Mealie ----------------------------------------------------------------
# URL of the Mealie instance this agent lives next to.
MEALIE_URL=https://recipes.epetersons.com
# Long-lived service API token for the `mealie-agent` service account in
# Mealie. Used by scripts/sync_recipes.py. Per-user chat uses the end-user's
# JWT (verified via /api/users/self) — no shared secret.
MEALIE_API_TOKEN=eyJhbGciOi...

# --- Web search ------------------------------------------------------------
# Brave Search API key for the web_search tool (general questions Rex's
# kitchen-specific tools can't answer). Free tier: 2k queries/mo at 1 q/s.
# Get one at https://brave.com/search/api/. Tool degrades gracefully if
# unset — Rex just can't web-search.
BRAVE_API_KEY=

# --- Deploy webhook --------------------------------------------------------
# Random 32-byte secret. The host-side systemd path+service units watch
# .deploy-trigger; POST /api/deploy from n8n (with Authorization: Bearer
# DEPLOY_TOKEN) writes the trigger, the host runs deploy.sh.
DEPLOY_TOKEN=change-me-random-32-bytes
DEPLOY_TRIGGER=/opt/mealie-agent/.deploy-trigger
